@page
@model BaistClubAutomation.Pages.RecordScoreModel
@{
}
@page
@model RecordScoreModel
@{
    ViewData["Title"] = "Record Player Score";
}

<h2>Record Player Score</h2>

<form method="post">
    <div class="row mb-3">
        <div class="col">
            <label>Date of Round</label>
            <input asp-for="ScoreEntry.Date" type="date" class="form-control" required />
        </div>
        <div class="col">
            <label>Golf Course</label>
            <input asp-for="ScoreEntry.CourseName" type="text" class="form-control" placeholder="Club BAIST" required />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col">
            <label>Course Rating</label>
            <input asp-for="ScoreEntry.CourseRating" type="number" step="0.1" class="form-control" placeholder="70.9" required />
        </div>
        <div class="col">
            <label>Slope Rating</label>
            <input asp-for="ScoreEntry.SlopeRating" type="number" class="form-control" placeholder="127" required />
        </div>
    </div>

    <h4>Scorecard Details</h4>
    <div class="table-responsive">
        <table class="table table-bordered text-center">
            <thead class="table-dark">
                <tr>
                    @for (int i = 1; i <= 9; i++) { <th>@i</th> }
                    <th>OUT</th>
                    @for (int i = 10; i <= 18; i++) { <th>@i</th> }
                    <th>IN</th>
                    <th>TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    @for (int i = 0; i < 18; i++)
                    {
                        if (i == 9) { <td><input type="text" id="outTotal" class="form-control" readonly /></td> }
                        <td>
                            <input asp-for="ScoreEntry.HoleScores[i]" class="form-control hole-input" type="number" min="1" max="15" required />
                        </td>
                    }
                    <td><input type="text" id="inTotal" class="form-control" readonly /></td>
                    <td><input asp-for="ScoreEntry.TotalScore" type="number" id="grandTotal" class="form-control" readonly /></td>
                </tr>
            </tbody>
        </table>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Submit Score</button>
</form>

@section Scripts {
    <script>
        
        $(".hole-input").on("input", function() {
            let total = 0;
            $(".hole-input").each(function() {
                total += Number($(this).val()) || 0;
            });
            $("#grandTotal").val(total);
        });
    </script>
}