@page
@model BaistClubAutomation.Pages.RecordScoreModel
@{
    ViewData["Title"] = "Record Score";
}

<h2>@ViewData["Title"]</h2>
<form method="post">
    <div class="mb-3">
        <label>Member Number</label>
        <input asp-for="ScoreEntry.MemberNumber" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Date Played</label>
        <input asp-for="ScoreEntry.DatePlayed" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Course Rating</label>
        <input asp-for="ScoreEntry.CourseRating" type="number" step="0.1" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Slope Rating</label>
        <input asp-for="ScoreEntry.SlopeRating" class="form-control" />
    </div>

    <h4>Hole Scores</h4>
    <div class="row">
        @for (int i = 0; i < 18; i++)
        {
            <div class="col-1">
                <label>H@(i + 1)</label>
                <input asp-for="ScoreEntry.HoleScores[i]" class="form-control" />
            </div>
        }
    </div>
    <button type="submit" class="btn btn-primary mt-3">Submit Score</button>
</form>